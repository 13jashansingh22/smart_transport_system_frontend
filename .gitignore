app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/frontend/android/app/debug
/frontend/android/app/profile
/frontend/android/app/release

# Android local Gradle cache/state (machine-specific)
/frontend/android/.gradle/
/frontend/android/.gradle-local/
/frontend/android/.gradle-user-home/
/frontend/android/local.properties
/frontend/android/key.properties
*.jks
*.keystore

# Local environment files
.env
.env.*

# iOS local build artifacts and dependencies
/frontend/ios/Pods/
/frontend/ios/.symlinks/
/frontend/ios/Flutter/ephemeral/
